import scipy
def asses_Gender_assessment_file(file, save_file):
    df = pd.read_csv(file)
    df.fillna(0, inplace=True)
    classifier = set(df.classifier.unique())
    features = set(df.features.unique())
    res_list = []
    for c in classifier:
        for f in features:
            df_copy = df.copy(deep=True)
            df_copy = df_copy[df_copy['features']==f]
            df_copy = df_copy[df_copy['classifier']==c]
            #assert df_copy.shape[0] > 9 #make sure i have a minimum number of entries to base myself on
            res = scipy.stats.ranksums(df_copy['P(G1|G1)'], df_copy['P(G2|G1)'], alternative='two-sided',  nan_policy='raise')
            res_list.append({'pvalue':res.pvalue, 'classifier': c, 'features':f, 'x':'P(G1|G1)', 'y':'P(G2|G1)'})
            res = scipy.stats.ranksums(df_copy['P(G2|G2)'], df_copy['P(G1|G2)'], alternative='two-sided',
                                        nan_policy='raise')#if wilcoxson: method='exact',
            res_list.append({'pvalue': res.pvalue, 'classifier': c, 'features': f, 'x': 'P(G2|G2)', 'y': 'P(G1|G2)'})
            res = scipy.stats.ranksums(df_copy['P(G2|G2)'], df_copy['P(G1|G1)'], alternative='two-sided',
                                        nan_policy='raise')#if wilcoxson: method='exact',
            res_list.append({'pvalue': res.pvalue, 'classifier': c, 'features': f, 'x': 'P(G2|G2)', 'y': 'P(G1|G1)'})
            res = scipy.stats.ranksums(df_copy['P(G1|G2)'], df_copy['P(G2|G1)'], alternative='two-sided',
                                        nan_policy='raise')#if wilcoxson: method='exact',
            res_list.append({'pvalue': res.pvalue, 'classifier': c, 'features': f, 'x': 'P(G1|G2)', 'y': 'P(G2|G1)'})
    df = pd.DataFrame.from_dict(res_list)
    df.to_csv(save_file)
    return None


