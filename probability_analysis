def calculate_probabilities_misclassification(author_gender_csv, Edges_csv, G1, G2):
    """
    calculates p(mis|gendergroup)
    :param author_lang_csv: csv containing info about authors native language (the index file)
    :param Edges_csv: file containing classifier predictions
    :param G1: Group of Gender 1
    :param G2: Group of Gender 2
    :return: dict
    """
    dict_res = {}
    #Step 0: Load data
    df_gender = pd.read_csv(author_gender_csv)
    df_gender.drop_duplicates(inplace=True)
    try:
        df_gender=df_gender[['author_name', 'Gender']]
    except:
        print("Input unusable")
        raise ValueError
    dict_gender = {}
    for index, row in df_gender.iterrows():
        dict_gender[row[0]] = row[1]
    df_class = pd.read_csv(Edges_csv)
    source = 'true'
    target = 'predicted'
    df_class['G_source'] = df_class[source].apply(lambda key: dict_gender[key])
    #First step: general misclassification
    #Pr(misclassified|englishspeaker)
    df_class['mis_gen'] = df_class[source].ne(df_class[target]) #The failstate is if its neq
    #Assumption in dataset not for a given user
    no_G1 = df_class[df_class['G_source']==G1].shape[0] #number G1
    no_G2 = df_class[df_class['G_source']==G2].shape[0] #number G2
    #p(mis|en) = #mis_union_en/#en
    df_temp = df_class.copy(deep=True)#only G1
    df_temp = df_temp[df_temp['G_source']==G1]
    no_mis_and_G1 = df_temp['mis_gen'].sum()
    df_temp = df_class.copy(deep=True)#only G2
    df_temp = df_temp[df_temp['G_source']==G2]
    no_mis_and_G2 = df_temp['mis_gen'].sum()
    dict_res['P(mis|G1)']=no_mis_and_G1/no_G1
    dict_res['P(mis|G2)']=no_mis_and_G2/no_G2
    return dict_res

