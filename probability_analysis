    """
    Create file with accuracy and F1 (in case someone f*** up and deletes the accuracy file)
    :param input_dir: directory with edge files; all relevant info in filename
    :param output_file: file with result
    :return: None
    """
    files_to_treat = os.listdir(input_dir)
    result = []
    for file in files_to_treat:
        res = file.split('_')
        if 'edges' in res[0]:
            iteration = res[1][-1]
            mode = res[2]
            noauth = res[3][9:]
            gender1 = res[4]
            no_gender1 = re.findall('\d+',res[4])[0]
            gender2 = res[5]
            no_gender2 = re.findall('\d+',res[5])[0]
            trainsize = res[7][9:]
            classifier = res[8][10:]
            features = '_'.join(res[9:])[:-4]
            df = pd.read_csv(os.path.join(input_dir, file))
            # cr = classification_report(df['true'], df['predicted'])
            # macro_precision = cr['macro avg']['precision']
            # macro_recall = cr['macro avg']['recall']
            # macro_f1 = cr['macro avg']['f1-score']
            # accuracy = cr['accuracy']
            accuracy = accuracy_score(df['true'], df['predicted'])
            F1 = f1_score(df['true'], df['predicted'], average='micro')
            result.append({'iteration':iteration, 'mode': mode, '#authors':noauth,
                           'gender1': gender1, 'no_gender1': no_gender1, 'gender2': gender2, 'no_gender2': no_gender2, 'num_train_words':trainsize,
                           'classifier': classifier, 'Features': features, 'Accuracy':accuracy,
                           'F1':F1})
    df = pd.DataFrame.from_dict(result)
    df.to_csv(output_file)
    return None


