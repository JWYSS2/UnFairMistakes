def account_based_voting(dir_with_rankings, threshold, index):
    """Idea: count all classifications for an author as votes, only take votes with a given certainty (p>threshold) into account"""
    files = [file for file in os.listdir(dir_with_rankings) if os.path.isfile(os.path.join(dir_with_rankings, file))]#only files
    files = [file for file in files if 'rankings_' in file]#only ranking files
    df_index = pd.read_csv(index)[['author_name', 'Gender']]
    df_index.drop_duplicates(subset=['author_name'], inplace=True)
    native = {}
    for author in df_index.iterrows():
        native[author[1]['author_name']] = author[1]['Gender']
    res = []
    for file in files:
        start = file.split('_')
        #rankings_iteration9_modesubstitute_noauthors4_Femaleauthors4_Transauthors0_unchunked_trainsize5000_classifierlogR_style_features_normalized_new
        iteration=re.findall("\d+",start[1])
        no_authors = re.findall("\d+",start[3])
        Gender1, no_g1 = start[4].split("authors")[0],  int(start[4].split("authors")[1])
        Gender2, no_g2 = start[5].split("authors")[0],  int(start[5].split("authors")[1])
        classifer = start[8][10:]
        mode = start[2][4:]
        feature = "_".join(start[9:])[:-4]
        df_temp = pd.read_csv(os.path.join(dir_with_rankings, file))
        #df_temp.reset_index(inplace=True)
        column_votes = list(df_temp.columns)
        if '0' in column_votes:
            column_votes.remove('0')
        elif 'author' in column_votes:
            column_votes.remove('author')
            df_temp.rename(columns={'author':'0'}, inplace=True)
        else:
            raise ValueError
        df_temp_1 = df_temp[column_votes]
        df_temp['highest']=df_temp_1.idxmax(axis=1)
        df_temp['highest_value']=df_temp_1.max(axis=1)
        df_temp['Gender_true'] = df_temp['0'].apply(lambda string: native[string])
        df_temp['Gender_highest'] = df_temp['highest'].apply(lambda string: native[string])
        df_temp = df_temp[['0', 'Gender_true','highest', 'highest_value', 'Gender_highest']]
        df_temp = df_temp[df_temp['highest_value'].astype(float)>threshold]
        authors_true = df_temp['0'].unique()
        for author in authors_true:
            df_temp_1 = df_temp[df_temp['0']==author]
            total_votes = df_temp_1.shape[0]
            most_votes = df_temp_1.groupby(['highest']).count()
            most_votes.reset_index(inplace=True)
            most_voted = most_votes['0'].max()
            most_voted_v = most_votes[most_votes['0']==most_voted]['highest'].values
            if len(most_voted_v)!=1:
                #choose the one with the highest mean probability
                mean_prob = pd.DataFrame(df_temp_1.groupby(['highest'])['highest_value'].mean())
                mean_prob.reset_index(inplace=True)
                res.append({"iteration":iteration, "classifier":classifer, "feature": feature,
                                "mode":mode, "Gender1":Gender1, "noG1":no_g1, "Gender2":Gender2, "noG2":no_g2, "no_authors":no_authors,
                            'true_author': author, 'voted_for':  mean_prob.max()['highest'],'how_many_votes':most_voted, 'total_votes': total_votes, 'threshhold': threshold, 'Native_true': native[author], 'Native_voted': native[mean_prob.max()['highest']]})

            else:
                res.append({"iteration":iteration, "classifier":classifer, "feature": feature,
                                "mode":mode, "Gender1":Gender1, "noG1":no_g1, "Gender2":Gender2, "noG2":no_g2, "no_authors":no_authors,'true_author': author, 'voted_for': most_voted_v[0], 'how_many_votes':most_voted, 'total_votes': total_votes, 'threshhold': threshold, 'Native_true': native[author], 'Native_voted': native[most_voted_v[0]]})

def voted_to_accuracy(voting_file, res_file):
    df_v = pd.read_csv(voting_file)
    res = []
    for threshold in df_v.threshhold.unique():
        df_temp = df_v[df_v['threshhold']==threshold]
        for classifier in df_v.classifier.unique():
            df_temp_c = df_temp[df_temp['classifier'] == classifier]
            for feature in df_v.feature.unique():
                df_temp_t = df_temp_c[df_temp_c['feature']==feature]
                for no_N in df_temp_t.noG1.unique():
                    df_temp_no = df_temp_t[df_temp_t['noG1']==no_N]
                    for iteration in df_temp_no.iteration.unique():
                        df_temp_it = df_temp_no[df_temp_no['iteration']==iteration]
                        cr = classification_report(df_temp_it['true_author'].astype(str), df_temp_it['voted_for'].astype(str), output_dict=True)
                        macro_precision = cr['macro avg']['precision']
                        macro_recall = cr['macro avg']['recall']
                        macro_f1 = cr['macro avg']['f1-score']
                        accuracy = cr['accuracy']
                        cr_N = classification_report(df_temp_no['Native_true'].astype(str), df_temp_no['Native_voted'].astype(str), output_dict=True)
                        res.append({'no_G1_authors':no_N, 'treshhold': threshold, 'Features': feature, 'classifier': classifier, 'Accuracy':accuracy,
                                   'F1':macro_f1, 'precision':macro_precision, 'recall': macro_recall, 'macro_precision_G': cr_N['macro avg']['precision'],
                        'recall_G': cr_N['macro avg']['recall'],
                        'F1_G': cr_N['macro avg']['f1-score'],
                        'Accuracy_G': cr_N['accuracy'], 'iteration':iteration})
    df_res = pd.DataFrame.from_dict(res)
    df_res.to_csv(res_file, index=False)
    return None

